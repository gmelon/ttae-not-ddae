---
interface Props {
  title?: string;
  description?: string;
  canonical?: string;
}

const {
  title = "떄 가 아니라 때 — 맥 한글 오타 자동 교정",
  description = "맥에서 한글 오타 자동 교정. 빠르게 칠 때 생기는 떄·꺠·뺴·쨰 같은 글자를 입력 즉시 바꿔주는 macOS 메뉴바 앱입니다.",
  canonical,
} = Astro.props;

const siteUrl = "https://ttae.gmelon.dev";
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImage = `${siteUrl}/logo.png`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="맥 한글 오타 자동 수정, 맥 한글 오타 교정, 한글 떄 쨰 꺠 뺴, macOS 한글 교정, 맥 한글 오타 수정기, 떄가아니라때, 맥 메뉴바 앱"
    />
    <meta name="author" content="gmelon" />
    <link rel="canonical" href={canonicalUrl} />

    <meta name="theme-color" content="#ffffff" />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/png" href="/logo_transparent.png" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="떄 가 아니라 때" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ko_KR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
    />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        name: "떄 가 아니라 때",
        applicationCategory: "UtilitiesApplication",
        operatingSystem: "macOS 14+",
        url: siteUrl,
        description,
        author: {
          "@type": "Person",
          name: "gmelon",
          url: "https://github.com/gmelon",
        },
        offers: {
          "@type": "Offer",
          price: "0",
          priceCurrency: "KRW",
        },
        downloadUrl:
          "https://github.com/gmelon/ttae-not-ddae/releases/latest",
        softwareVersion: "1.0.0",
        license: "https://opensource.org/licenses/MIT",
      })}
    />
  </head>
  <body>
    <slot />
    <style is:global>
      :root {
        color-scheme: light;

        --bg: #ffffff;
        --bg-elev: #fafafa;
        --bg-elev-2: #f3f3f3;
        --border: rgba(15, 15, 18, 0.08);
        --border-strong: rgba(15, 15, 18, 0.14);

        --text: #0f0f12;
        --text-muted: #55555a;
        --text-dim: #8a8a90;

        --accent: #2c8a5a;
        --accent-hover: #226c45;
        --accent-soft: rgba(44, 138, 90, 0.10);
        --accent-shadow: rgba(44, 138, 90, 0.22);

        --strike: #dc2626;

        --radius-sm: 8px;
        --radius: 14px;
        --radius-lg: 22px;

        --maxw: 1080px;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family:
          "Pretendard Variable",
          Pretendard,
          -apple-system,
          BlinkMacSystemFont,
          "Apple SD Gothic Neo",
          system-ui,
          sans-serif;
        font-size: 16.5px;
        font-weight: 400;
        line-height: 1.65;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      h1,
      h2,
      h3 {
        margin: 0;
        line-height: 1.15;
        letter-spacing: -0.022em;
        font-weight: 600;
      }

      p {
        margin: 0;
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 24px;
      }

      .strike-wrong {
        position: relative;
        color: var(--text-dim);
      }
      .strike-wrong::after {
        content: "";
        position: absolute;
        left: -6%;
        right: -6%;
        top: 52%;
        height: 2px;
        background: var(--strike);
        transform: rotate(-7deg);
        border-radius: 2px;
      }

      .right-glyph {
        color: var(--text);
      }

      .visually-hidden {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      @media (max-width: 640px) {
        body {
          font-size: 15.5px;
        }
      }
    </style>
  </body>
</html>

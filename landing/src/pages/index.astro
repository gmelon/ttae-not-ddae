---
import Layout from "../layouts/Layout.astro";
import {
  getDmgDownloadUrl,
  getReleasesPageUrl,
  getRepoUrl,
} from "../lib/version";

const releaseUrl = getReleasesPageUrl();
const dmgUrl = getDmgDownloadUrl();
const repoUrl = getRepoUrl();

const mappings: { wrong: string; right: string }[] = [
  { wrong: "떄", right: "때" },
  { wrong: "뗴", right: "떼" },
  { wrong: "꺠", right: "깨" },
  { wrong: "꼐", right: "께" },
  { wrong: "뺴", right: "빼" },
  { wrong: "뼤", right: "뻬" },
  { wrong: "썌", right: "쌔" },
  { wrong: "쎼", right: "쎄" },
  { wrong: "쨰", right: "째" },
  { wrong: "쪠", right: "쩨" },
];

const features: { title: string; body: string }[] = [
  {
    title: "치는 순간 자동 교정",
    body: "잘못된 문자를 인식하는 순간, <strong>자동으로 교정이 수행됩니다.</strong> 타이핑 흐름을 방해하지 않아요.",
  },
  {
    title: "한글 입력일 때만 동작",
    body: "<strong>한국어 두벌식</strong>일 때만 작동합니다. 영문이나 코드 작성 중에는 끼어들지 않아요.",
  },
  {
    title: "백그라운드에서 가볍게 동작",
    body: "Dock 에 뜨지 않고, <strong>메뉴바에서도 숨김 처리</strong> 할 수 있습니다.",
  },
  {
    title: "오픈소스라서 안심",
    body: "코드 전체가 <strong>GitHub 에 공개</strong>되어 있습니다. 키 입력을 다루는 앱인 만큼 직접 들여다보실 수 있고, <strong>어디로도 데이터를 보내지 않는다</strong>는 사실도 그 코드 안에서 확인하실 수 있어요.",
  },
];

const stripHtml = (html: string): string =>
  html
    .replace(/<\/?[^>]+>/g, "")
    .replace(/\s+/g, " ")
    .trim();

const faqs: { q: string; a: string }[] = [
  {
    q: "정확히 어떤 글자가 교정되나요?",
    a: "쌍자음(ㄲ ㄸ ㅃ ㅆ ㅉ) 과 이중모음(ㅒ ㅖ) 이 결합된 <strong>10개의 음절뿐</strong>입니다. 위의 매핑표 그대로이고, <strong>그 외 글자는 절대 건드리지 않아요.</strong>",
  },
  {
    q: "왜 손쉬운 사용 권한이 필요한가요?",
    a: "잘못된 글자를 감지하고 올바른 글자로 다시 입력하려면 시스템의 <strong>손쉬운 사용(Accessibility) 권한</strong>이 필요합니다. <strong>시스템 설정 > 개인 정보 보호 및 보안 > 손쉬운 사용</strong> 에서 켜주시면 됩니다.",
  },
  {
    q: "키보드 입력이 어딘가로 전송되나요?",
    a: "<strong>아니요.</strong> 모든 처리는 컴퓨터 안에서만 일어납니다. <strong>외부로 보내는 코드는 단 한 줄도 없으며,</strong> 코드 전체가 GitHub 에 공개되어 있어 직접 확인하실 수 있어요.",
  },
  {
    q: "두벌식이 아닌 다른 한글 자판도 지원하나요?",
    a: "현재는 <strong>두벌식 표준 자판</strong>만 지원합니다. 세벌식 등 다른 자판은 키 위치가 달라 추후 별도 작업이 필요해요.",
  },
  {
    q: "특정 단어는 교정에서 제외하고 싶어요.",
    a: "<strong>환경설정 > 예외 단어</strong> 탭에서 단어를 추가하면 <strong>교정 대상에서 빠집니다.</strong>",
  },
  {
    q: "어떤 macOS 버전에서 동작하나요?",
    a: "<strong>macOS 14 (Sonoma) 이상</strong>에서 동작합니다.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: {
      "@type": "Answer",
      text: stripHtml(a),
    },
  })),
};
---

<Layout>
  <header class="nav">
    <div class="container nav-row">
      <a href="/" class="brand" aria-label="떄 가 아니라 때 홈">
        <img src="/logo_transparent.png" alt="" width="26" height="26" />
        <span class="brand-text">
          <span class="strike-wrong">떄</span>
          <span class="brand-tail">가 아니라</span>
          <span class="right-glyph">때</span>
        </span>
      </a>
      <nav class="nav-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={dmgUrl} class="nav-cta" aria-label="macOS 다운로드">
          <svg
            class="apple-mark"
            viewBox="0 0 384 512"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7-56.6.9-116.5 44.2-116.5 132.3 0 26 4.8 52.9 14.4 80.6 12.8 36.4 58.9 125.7 107 124.2 25.1-.6 42.8-17.9 75.5-17.9 31.7 0 48.1 17.9 76.1 17.9 48.5-.7 90.2-81.9 102.4-118.4-65.1-30.7-59.3-90-59.3-90.3zm-56.3-156.8c27.1-32.2 24.6-61.5 23.8-72-23.9 1.4-51.6 16.3-67.4 34.6-17.4 19.7-27.6 44-25.4 71.4 25.9 2 49.5-11.2 69-34z"
            ></path>
          </svg>
          <span class="nav-cta-text">macOS 다운로드</span>
        </a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1 class="hero-title">
          세상에<br />
          <span class="hero-line"
            ><span class="strike-wrong">떄</span> 라는 글자는</span
          ><br />
          <span class="hero-emph">없다.</span>
        </h1>

        <p class="hero-sub">
          떄. 꺠. 뺴. 쨰.<br class="break-md" />
          빠르게 타이핑하다보면 한 번쯤 보게되죠.<br class="break-md" />
          이 앱이 자동으로 교정해드립니다.
        </p>

        <div class="cta-row">
          <a href={dmgUrl} class="btn btn-primary btn-stack">
            <svg
              class="apple-mark apple-mark-lg"
              viewBox="0 0 384 512"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7-56.6.9-116.5 44.2-116.5 132.3 0 26 4.8 52.9 14.4 80.6 12.8 36.4 58.9 125.7 107 124.2 25.1-.6 42.8-17.9 75.5-17.9 31.7 0 48.1 17.9 76.1 17.9 48.5-.7 90.2-81.9 102.4-118.4-65.1-30.7-59.3-90-59.3-90.3zm-56.3-156.8c27.1-32.2 24.6-61.5 23.8-72-23.9 1.4-51.6 16.3-67.4 34.6-17.4 19.7-27.6 44-25.4 71.4 25.9 2 49.5-11.2 69-34z"
              ></path>
            </svg>
            <span class="btn-stack-text">
              <span class="btn-main">지금 다운로드</span>
              <span class="btn-sub">macOS 14+</span>
            </span>
          </a>
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-ghost">GitHub 코드 보기</a
          >
        </div>

        <p class="download-count" id="download-count" hidden>
          지금까지 <strong id="download-count-num">0</strong>번 다운로드됐어요
        </p>

        <div class="hero-demo" aria-hidden="true">
          <div class="demo-pair">
            <span class="demo-glyph wrong"
              ><span class="strike-wrong">떄</span></span
            >
            <span class="demo-arrow">→</span>
            <span class="demo-glyph right">때</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">
          방금도 <span class="hl">'떄'</span>라고 치셨나요?
        </h2>
        <div class="explainer">
          <p>
            바쁜 일상 속 우리는 자꾸만 '때'를 찾지만, 정작 손끝에 닿는 건 '떄'.
            빛날 떄, 무너질 떄, 다시 일어설 떄 — 그 모든 순간에도 우리가
            부르고 싶었던 건 '때'였습니다.
            <strong>쌍자음(ㄲ ㄸ ㅃ ㅆ ㅉ)</strong>은 한국어에서
            이중모음(ㅒ ㅖ)을 거의 만나지 않거든요.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-table">
      <div class="container">
        <h2 class="section-title">아래 10개의 오타를 자동으로 수정합니다</h2>

        <div class="mapping-grid">
          {
            mappings.map(({ wrong, right }) => (
              <div class="mapping-card">
                <div class="mapping-pair">
                  <span class="mapping-wrong">
                    <span class="strike-wrong">{wrong}</span>
                  </span>
                  <span class="mapping-arrow">→</span>
                  <span class="mapping-right">{right}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">동작 방식</h2>
        <div class="features">
          {
            features.map(({ title, body }) => (
              <div class="feature">
                <h3 class="feature-title">{title}</h3>
                <p class="feature-body" set:html={body} />
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-download">
      <div class="container download-card">
        <div class="download-info">
          <h2 class="download-title">설치하기</h2>
          <ol class="install-steps">
            <li>.dmg 다운로드</li>
            <li>
              더블 클릭 후, <code>Ttae.app</code> 을 Applications 폴더로 드래그
            </li>
            <li>
              처음 실행 시 시스템 설정 &gt; 개인 정보 보호 및 보안 &gt; 손쉬운 사용 켜주기
            </li>
          </ol>
        </div>
        <div class="download-actions">
          <a href={dmgUrl} class="btn btn-primary btn-lg btn-stack">
            <svg
              class="apple-mark apple-mark-lg"
              viewBox="0 0 384 512"
              aria-hidden="true"
              focusable="false"
            >
              <path
                fill="currentColor"
                d="M318.7 268.7c-.2-36.7 16.4-64.4 50-84.8-18.8-26.9-47.2-41.7-84.7-44.6-35.5-2.8-74.3 20.7-88.5 20.7-15 0-49.4-19.7-76.4-19.7-56.6.9-116.5 44.2-116.5 132.3 0 26 4.8 52.9 14.4 80.6 12.8 36.4 58.9 125.7 107 124.2 25.1-.6 42.8-17.9 75.5-17.9 31.7 0 48.1 17.9 76.1 17.9 48.5-.7 90.2-81.9 102.4-118.4-65.1-30.7-59.3-90-59.3-90.3zm-56.3-156.8c27.1-32.2 24.6-61.5 23.8-72-23.9 1.4-51.6 16.3-67.4 34.6-17.4 19.7-27.6 44-25.4 71.4 25.9 2 49.5-11.2 69-34z"
              ></path>
            </svg>
            <span class="btn-stack-text">
              <span class="btn-main">지금 다운로드</span>
              <span class="btn-sub">macOS 14+</span>
            </span>
          </a>
          <a href={releaseUrl} target="_blank" rel="noopener" class="btn-link">
            전체 릴리즈 노트 보기
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">자주 묻는 질문</h2>
        <script
          type="application/ld+json"
          set:html={JSON.stringify(faqSchema)}
        />
        <div class="faqs">
          {
            faqs.map(({ q, a }) => (
              <details class="faq">
                <summary>{q}</summary>
                <p set:html={a} />
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <script is:inline>
    (() => {
      const KEY = "ttae-dl-count";
      const TTL = 5 * 60 * 1000;
      const el = document.getElementById("download-count");
      const num = document.getElementById("download-count-num");
      if (!el || !num) return;

      const reveal = (count) => {
        if (typeof count !== "number" || count <= 0) return;
        num.textContent = count.toLocaleString("ko-KR");
        el.hidden = false;
      };

      try {
        const cached = sessionStorage.getItem(KEY);
        if (cached) {
          const { count, ts } = JSON.parse(cached);
          if (Date.now() - ts < TTL) {
            reveal(count);
            return;
          }
        }
      } catch (_) {}

      fetch(
        "https://api.github.com/repos/gmelon/ttae-not-ddae/releases?per_page=100",
        { headers: { Accept: "application/vnd.github+json" } }
      )
        .then((r) => (r.ok ? r.json() : null))
        .then((releases) => {
          if (!Array.isArray(releases)) return;
          let total = 0;
          for (const r of releases) {
            for (const a of r.assets || []) {
              if (typeof a.name === "string" && a.name.endsWith(".dmg")) {
                total += a.download_count || 0;
              }
            }
          }
          try {
            sessionStorage.setItem(
              KEY,
              JSON.stringify({ count: total, ts: Date.now() })
            );
          } catch (_) {}
          reveal(total);
        })
        .catch(() => {});
    })();
  </script>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="strike-wrong">떄</span>
        <span class="brand-tail">가 아니라</span>
        <span class="right-glyph">때</span>
      </div>
      <div class="footer-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={releaseUrl} target="_blank" rel="noopener">Releases</a>
        <a
          href="https://github.com/gmelon/ttae-not-ddae/blob/main/LICENSE"
          target="_blank"
          rel="noopener">MIT</a
        >
      </div>
      <div class="footer-meta">© 2026 떄가아니라때 contributors</div>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    background: rgba(250, 250, 246, 0.7);
    border-bottom: 1px solid var(--border);
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    font-size: 15px;
  }
  .brand img {
    border-radius: 6px;
  }
  .brand-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0.32em;
  }
  .brand-tail {
    color: var(--text-muted);
    font-weight: 400;
  }
  .nav-links {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--text-muted);
  }
  .nav-links a {
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
    font-weight: 500;
  }
  .nav-links a:hover {
    background: var(--bg-elev);
    color: var(--text);
  }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: #fff !important;
    background: var(--accent);
    border: 1px solid var(--accent);
  }
  .nav-cta:hover {
    background: var(--accent-hover) !important;
    border-color: var(--accent-hover);
  }

  .hero {
    padding: 110px 0 84px;
    text-align: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }
  .hero-title {
    font-size: clamp(44px, 7.4vw, 80px);
    font-weight: 600;
    letter-spacing: -0.028em;
    line-height: 1.1;
  }
  .hero-line {
    display: inline-block;
    padding: 0 0.05em;
  }
  .hero-emph {
    color: var(--accent);
    font-weight: 700;
  }
  .hero-sub {
    max-width: 580px;
    color: var(--text-muted);
    font-size: clamp(16px, 1.55vw, 18.5px);
    font-weight: 400;
    line-height: 1.7;
  }
  .break-md {
    display: none;
  }
  @media (min-width: 720px) {
    .break-md {
      display: inline;
    }
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 4px;
  }

  .download-count {
    margin-top: -14px;
    color: var(--text-dim);
    font-size: 13.5px;
    font-weight: 500;
    letter-spacing: -0.005em;
    animation: dl-count-in 0.35s ease-out;
  }
  .download-count strong {
    color: var(--accent);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  @keyframes dl-count-in {
    from {
      opacity: 0;
      transform: translateY(-2px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    font-size: 15px;
    transition: transform 0.06s ease, background 0.15s ease,
      border-color 0.15s ease, box-shadow 0.15s ease;
    border: 1px solid transparent;
    will-change: transform;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.4) inset,
      0 4px 14px var(--accent-shadow);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
  }
  .btn-ghost {
    background: var(--bg-elev);
    color: var(--text);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    border-color: var(--border-strong);
  }
  .apple-mark {
    width: 0.95em;
    height: 1.05em;
    transform: translateY(-1px);
    flex-shrink: 0;
  }
  .apple-mark-lg {
    width: 1.4em;
    height: 1.55em;
    transform: translateY(-1px);
  }
  .btn-stack {
    padding: 12px 22px;
    gap: 12px;
  }
  .btn-stack-text {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.2;
  }
  .btn-main {
    font-size: 15.5px;
    font-weight: 600;
  }
  .btn-sub {
    font-size: 11.5px;
    font-weight: 500;
    opacity: 0.85;
    letter-spacing: 0.01em;
  }
  .btn-lg {
    padding: 15px 26px;
    font-size: 15.5px;
  }

  .hero-demo {
    margin-top: 28px;
    padding: 30px 22px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: 100%;
    max-width: 520px;
    box-shadow: 0 1px 2px rgba(15, 15, 18, 0.04),
      0 8px 24px rgba(15, 15, 18, 0.04);
  }
  .demo-pair {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
  }
  .demo-glyph {
    font-size: 56px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .demo-glyph.wrong {
    color: var(--text-dim);
  }
  .demo-glyph.right {
    color: var(--accent);
  }

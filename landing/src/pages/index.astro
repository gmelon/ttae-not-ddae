---
import Layout from "../layouts/Layout.astro";

const releaseUrl =
  "https://github.com/gmelon/ttae-not-ddae/releases/latest";
const dmgUrl =
  "https://github.com/gmelon/ttae-not-ddae/releases/latest/download/Ttae-1.0.0.dmg";
const repoUrl = "https://github.com/gmelon/ttae-not-ddae";

const mappings: { wrong: string; right: string }[] = [
  { wrong: "떄", right: "때" },
  { wrong: "뗴", right: "떼" },
  { wrong: "꺠", right: "깨" },
  { wrong: "꼐", right: "께" },
  { wrong: "뺴", right: "빼" },
  { wrong: "뼤", right: "뻬" },
  { wrong: "썌", right: "쌔" },
  { wrong: "쎼", right: "쎄" },
  { wrong: "쨰", right: "째" },
  { wrong: "쪠", right: "쩨" },
];

const features = [
  {
    title: "쳤다 싶은 순간 이미 교정",
    body: "음절이 완성되는 순간 backspace + 올바른 글자 재입력이 자동으로 이뤄집니다. 평소 흐름을 끊지 않습니다.",
  },
  {
    title: "한글 입력일 때만 동작",
    body: "현재 입력 소스가 한국어 두벌식일 때만 활성화됩니다. 영문·코드 작성 중에는 절대 끼어들지 않습니다.",
  },
  {
    title: "조용한 메뉴바 앱",
    body: "Dock 에 뜨지 않고 메뉴바 한 칸만 차지합니다. 누적 교정 횟수, 자동 교정 on/off, 예외 단어 관리만 있는 깔끔한 UI.",
  },
  {
    title: "오픈소스, 서명·공증 완료",
    body: "MIT 라이선스로 코드 전체 공개. Apple Developer ID 서명 + 공증된 .dmg 로 배포되어 Gatekeeper 경고 없이 설치됩니다.",
  },
];

const faqs = [
  {
    q: "정확히 어떤 글자가 교정되나요?",
    a: "쌍자음(ㄲ ㄸ ㅃ ㅆ ㅉ) 과 이중모음(ㅒ ㅖ) 이 결합된 10개의 음절입니다. 위의 매핑 표 그대로이고, 그 외 음절은 절대 건드리지 않습니다.",
  },
  {
    q: "왜 Accessibility 권한이 필요한가요?",
    a: "키 입력을 감지하고 잘못된 음절을 올바른 음절로 바꿔 다시 입력하려면 시스템의 Accessibility(손쉬운 사용) 권한이 필요합니다. 권한은 시스템 설정 > 개인 정보 보호 및 보안 > 손쉬운 사용 에서 부여합니다.",
  },
  {
    q: "키보드 입력이 어딘가로 전송되나요?",
    a: "아니요. 모든 처리는 로컬에서만 일어납니다. 네트워크 통신, 분석 도구, 외부 서버 전송 같은 코드는 전혀 없으며 코드 전체가 GitHub 에 공개되어 있습니다.",
  },
  {
    q: "두벌식이 아닌 다른 한글 자판도 지원하나요?",
    a: "현재는 두벌식 표준 자판만 지원합니다. 세벌식 등 다른 자판은 키 매핑이 달라 별도 작업이 필요합니다.",
  },
  {
    q: "특정 단어는 교정에서 제외하고 싶어요.",
    a: "환경설정의 \"예외 단어\" 탭에서 단어를 추가하면 해당 단어를 입력해도 교정되지 않습니다. (현재 v1.0.0 의 교정 대상 음절만으로는 영향이 거의 없지만, 향후 사전 기반 검증 추가 시 사용됩니다.)",
  },
  {
    q: "지원 macOS 버전은?",
    a: "macOS 14 (Sonoma) 이상에서 동작합니다.",
  },
];
---

<Layout>
  <header class="nav">
    <div class="container nav-row">
      <a href="/" class="brand" aria-label="떄가아니라때 홈">
        <img src="/logo_transparent.png" alt="" width="28" height="28" />
        <span class="brand-text">
          <span class="strike-wrong">떄</span><span class="brand-tail">가 아니라 </span><span class="right-glyph">때</span>
        </span>
      </a>
      <nav class="nav-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={releaseUrl} target="_blank" rel="noopener" class="nav-cta">다운로드</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <span class="eyebrow">macOS · 한글 자동 교정</span>
        <h1 class="hero-title">
          세상에<br />
          <span class="wrong-block"><span class="strike-wrong">떄</span></span>
          라는 말은<br />
          <span class="hero-emph">없다.</span>
        </h1>

        <p class="hero-sub">
          빠르게 칠수록 Shift 가 모음까지 따라옵니다.<br class="break-md" />
          그 결과 떄·꺠·뺴·쨰 — 한국어에 존재할 수 없는 음절들.<br class="break-md" />
          입력되는 순간 바로잡습니다.
        </p>

        <div class="cta-row">
          <a href={dmgUrl} class="btn btn-primary" data-event="download">
            <span class="btn-arrow">↓</span>
            <span>v1.0.0 .dmg 다운로드</span>
          </a>
          <a href={repoUrl} target="_blank" rel="noopener" class="btn btn-ghost">
            GitHub 저장소
          </a>
        </div>

        <p class="hero-note">
          MIT · Apple Developer ID 서명 + 공증 · macOS 14+
        </p>

        <div class="hero-demo" aria-hidden="true">
          <div class="keystrokes">
            <span class="key">ㅉ</span>
            <span class="key">+</span>
            <span class="key">⇧</span>
            <span class="key">ㅒ</span>
            <span class="arrow">→</span>
            <span class="syllable wrong"><span class="strike-wrong">쨰</span></span>
            <span class="arrow tiny">⤳ 0.02s</span>
            <span class="syllable right">째</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">
          한국어 음운 규칙상,<br />
          <span class="hl">애초에 존재할 수 없는 음절</span>입니다.
        </h2>
        <div class="explainer">
          <p>
            표준국어대사전과 우리말샘 어디에도 떄·꺠·뺴·쨰 같은 단어는 없습니다.
            한국어에서 <strong>쌍자음(ㄲ·ㄸ·ㅃ·ㅆ·ㅉ)</strong> 은
            이중모음(ㅑ·ㅕ·ㅛ·ㅠ·ㅒ·ㅖ) 과 결합하지 않기 때문입니다.
            쌍자음은 단모음(ㅏ·ㅓ·ㅗ·ㅜ·ㅡ·ㅣ·ㅐ·ㅔ) 하고만 만납니다.
          </p>
          <p>
            즉 위 음절들은 유니코드에는 존재하지만 — 한글 완성형 11,172자 안에 있지만 —
            실제 한국어 단어에는 단 하나도 등장하지 않습니다.
            사실상 100% Shift 를 모음까지 누른 결과의 오타라는 뜻입니다.
          </p>
          <p class="explainer-tail">
            그래서 떄가아니라때는 이 패턴이 발견되는 즉시 자동으로 교정합니다.
            사전을 뒤질 필요도, 문맥을 추정할 필요도 없는 — 결정 가능한 오타.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-table">
      <div class="container">
        <h2 class="section-title">교정 대상 10개 음절</h2>
        <p class="section-sub">
          앱이 자동으로 바꾸는 모든 케이스. 그 외에는 절대 손대지 않습니다.
        </p>

        <div class="mapping-grid">
          {mappings.map(({ wrong, right }) => (
            <div class="mapping-card">
              <div class="mapping-pair">
                <span class="mapping-wrong"><span class="strike-wrong">{wrong}</span></span>
                <span class="mapping-arrow">→</span>
                <span class="mapping-right">{right}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">동작 방식</h2>
        <div class="features">
          {features.map(({ title, body }) => (
            <div class="feature">
              <h3 class="feature-title">{title}</h3>
              <p class="feature-body">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section section-download">
      <div class="container download-card">
        <div>
          <h2 class="download-title">설치하기</h2>
          <ol class="install-steps">
            <li>아래 .dmg 다운로드</li>
            <li>더블클릭으로 마운트, <code>Ttae.app</code> 을 Applications 폴더로 드래그</li>
            <li>처음 실행 시 시스템 설정 &gt; 개인 정보 보호 및 보안 &gt; 손쉬운 사용 에서 권한 부여</li>
          </ol>
        </div>
        <div class="download-actions">
          <a href={dmgUrl} class="btn btn-primary btn-lg">
            <span class="btn-arrow">↓</span>
            <span>Ttae-1.0.0.dmg</span>
          </a>
          <a href={releaseUrl} target="_blank" rel="noopener" class="btn-link">
            전체 릴리스 노트 보기
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">자주 묻는 질문</h2>
        <div class="faqs">
          {faqs.map(({ q, a }) => (
            <details class="faq">
              <summary>{q}</summary>
              <p>{a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="strike-wrong">떄</span>
        <span class="brand-tail"> 가 아니라 </span>
        <span class="right-glyph">때</span>
      </div>
      <div class="footer-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={releaseUrl} target="_blank" rel="noopener">Releases</a>
        <a
          href="https://github.com/gmelon/ttae-not-ddae/blob/main/LICENSE"
          target="_blank"
          rel="noopener">MIT License</a>
      </div>
      <div class="footer-meta">
        © 2026 떄가아니라때 contributors · Made with care in Korea
      </div>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    background: rgba(11, 11, 16, 0.6);
    border-bottom: 1px solid var(--border);
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 600;
    font-size: 15px;
  }
  .brand img {
    border-radius: 6px;
  }
  .brand-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }
  .brand-tail {
    color: var(--text-muted);
    font-weight: 500;
  }
  .nav-links {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14px;
    color: var(--text-muted);
  }
  .nav-links a {
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .nav-links a:hover {
    background: var(--bg-elev);
    color: var(--text);
  }
  .nav-cta {
    color: var(--text) !important;
    background: var(--accent-soft);
    border: 1px solid var(--accent-soft);
  }
  .nav-cta:hover {
    background: rgba(255, 90, 95, 0.22) !important;
  }

  .hero {
    padding: 96px 0 72px;
    text-align: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 22px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    font-size: 13px;
    color: var(--text-muted);
    letter-spacing: 0.02em;
  }
  .hero-title {
    font-size: clamp(40px, 7vw, 80px);
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .wrong-block {
    display: inline-block;
    padding: 0 0.05em;
  }
  .hero-emph {
    color: var(--accent);
  }
  .hero-sub {
    max-width: 560px;
    color: var(--text-muted);
    font-size: clamp(15px, 1.6vw, 18px);
  }
  .break-md {
    display: none;
  }
  @media (min-width: 720px) {
    .break-md {
      display: inline;
    }
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 6px;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 18px;
    border-radius: var(--radius-sm);
    font-weight: 600;
    font-size: 14.5px;
    transition: transform 0.06s ease, background 0.15s ease,
      border-color 0.15s ease;
    border: 1px solid transparent;
    will-change: transform;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
  }
  .btn-primary:hover {
    background: #ff7378;
  }
  .btn-ghost {
    background: var(--bg-elev);
    color: var(--text);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    border-color: var(--border-strong);
  }
  .btn-arrow {
    font-size: 13px;
    opacity: 0.9;
  }
  .btn-lg {
    padding: 14px 22px;
    font-size: 15.5px;
  }
  .hero-note {
    color: var(--text-dim);
    font-size: 13px;
    letter-spacing: 0.01em;
  }

  .hero-demo {
    margin-top: 28px;
    padding: 22px 18px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: 100%;
    max-width: 600px;
  }
  .keystrokes {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
    font-size: 16px;
    color: var(--text-muted);
  }
  .key {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 30px;
    height: 30px;
    padding: 0 8px;
    background: var(--bg);
    border: 1px solid var(--border-strong);
    border-radius: 6px;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo,
      monospace;
    font-size: 13px;
    color: var(--text);
  }
  .arrow {
    color: var(--text-dim);
  }
  .arrow.tiny {
    font-size: 12px;
  }
  .syllable {
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.02em;
  }
  .syllable.wrong {
    color: var(--text-dim);
  }
  .syllable.right {
    color: var(--accent);
  }

  .section {
    padding: 80px 0;
  }
  .section-title {
    font-size: clamp(26px, 3.4vw, 40px);
    font-weight: 700;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 16px;
  }
  .section-sub {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 36px;
    font-size: 15.5px;
  }
  .hl {
    color: var(--accent);
  }

  .explainer {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: var(--text-muted);
    font-size: 16px;
    text-align: left;
    padding: 28px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    margin-top: 24px;
  }
  .explainer strong {
    color: var(--text);
    font-weight: 600;
  }
  .explainer-tail {
    color: var(--text);
    border-top: 1px solid var(--border);
    padding-top: 14px;
    margin-top: 4px;
  }

  .mapping-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin-top: 24px;
  }
  .mapping-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 16px;
    transition: border-color 0.15s ease, transform 0.15s ease;
  }
  .mapping-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
  }
  .mapping-pair {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-size: 32px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }
  .mapping-wrong {
    color: var(--text-dim);
  }
  .mapping-arrow {
    color: var(--text-dim);
    font-size: 18px;
  }
  .mapping-right {
    color: var(--text);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
    margin-top: 28px;
  }
  .feature {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
  }
  .feature-title {
    font-size: 17px;
    font-weight: 600;
    margin-bottom: 8px;
  }
  .feature-body {
    color: var(--text-muted);
    font-size: 14.5px;
    line-height: 1.6;
  }

  .section-download {
    padding-top: 40px;
  }
  .download-card {
    background: linear-gradient(
      180deg,
      rgba(255, 90, 95, 0.08),
      rgba(255, 90, 95, 0.02) 60%,
      transparent
    );
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 36px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }
  @media (min-width: 760px) {
    .download-card {
      grid-template-columns: 1.4fr 1fr;
    }
  }
  .download-title {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 14px;
  }
  .install-steps {
    margin: 0;
    padding-left: 22px;
    color: var(--text-muted);
    line-height: 1.85;
  }
  .install-steps code {
    background: var(--bg-elev-2);
    padding: 1px 6px;
    border-radius: 5px;
    font-family: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo,
      monospace;
    font-size: 13.5px;
    color: var(--text);
  }
  .download-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }
  @media (min-width: 760px) {
    .download-actions {
      align-items: flex-end;
    }
  }
  .btn-link {
    color: var(--text-muted);
    font-size: 13.5px;
    border-bottom: 1px dashed var(--border-strong);
    padding-bottom: 1px;
  }
  .btn-link:hover {
    color: var(--text);
  }

  .faqs {
    max-width: 720px;
    margin: 24px auto 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0 18px;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }
  .faq[open] {

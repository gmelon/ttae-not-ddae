---
import Layout from "../layouts/Layout.astro";

const releaseUrl =
  "https://github.com/gmelon/ttae-not-ddae/releases/latest";
const dmgUrl =
  "https://github.com/gmelon/ttae-not-ddae/releases/latest/download/Ttae-1.0.0.dmg";
const repoUrl = "https://github.com/gmelon/ttae-not-ddae";

const mappings: { wrong: string; right: string }[] = [
  { wrong: "떄", right: "때" },
  { wrong: "뗴", right: "떼" },
  { wrong: "꺠", right: "깨" },
  { wrong: "꼐", right: "께" },
  { wrong: "뺴", right: "빼" },
  { wrong: "뼤", right: "뻬" },
  { wrong: "썌", right: "쌔" },
  { wrong: "쎼", right: "쎄" },
  { wrong: "쨰", right: "째" },
  { wrong: "쪠", right: "쩨" },
];

const features = [
  {
    title: "쳤다 싶은 순간 이미 교정",
    body: "음절이 완성되는 순간 backspace 와 올바른 글자가 자동으로 들어갑니다. 평소 타이핑 흐름을 끊지 않아요.",
  },
  {
    title: "한글 입력일 때만 동작",
    body: "현재 입력 소스가 한국어 두벌식일 때만 작동합니다. 영문이나 코드 작성 중에는 끼어들지 않아요.",
  },
  {
    title: "조용한 메뉴바 앱",
    body: "Dock 에 뜨지 않습니다. 메뉴바 한 칸에서 누적 교정 횟수, 자동 교정 토글, 예외 단어 관리만 보여주는 단순한 UI 입니다.",
  },
  {
    title: "오픈소스라서 안심",
    body: "MIT 라이선스로 코드 전체가 GitHub 에 공개되어 있습니다. 키 입력을 다루는 앱인 만큼 직접 들여다보실 수 있고, 어디로도 데이터를 보내지 않는다는 사실도 그 코드 안에서 확인하실 수 있어요.",
  },
];

const faqs = [
  {
    q: "정확히 어떤 글자가 교정되나요?",
    a: "쌍자음(ㄲ ㄸ ㅃ ㅆ ㅉ) 과 이중모음(ㅒ ㅖ) 이 결합된 10개의 음절뿐입니다. 위의 매핑표 그대로이고, 그 외 글자는 절대 건드리지 않아요.",
  },
  {
    q: "왜 손쉬운 사용 권한이 필요한가요?",
    a: "잘못된 글자를 감지하고 올바른 글자로 다시 입력하려면 시스템의 손쉬운 사용(Accessibility) 권한이 필요합니다. 시스템 설정 > 개인 정보 보호 및 보안 > 손쉬운 사용 에서 부여하실 수 있어요.",
  },
  {
    q: "키보드 입력이 어딘가로 전송되나요?",
    a: "아니요. 모든 처리는 로컬에서만 일어납니다. 외부 통신, 분석 도구, 서버 전송 같은 코드는 단 한 줄도 없으며, 코드 전체가 GitHub 에 공개되어 있어 직접 확인하실 수 있어요.",
  },
  {
    q: "두벌식이 아닌 다른 한글 자판도 지원하나요?",
    a: "현재는 두벌식 표준 자판만 지원합니다. 세벌식 등 다른 자판은 키 매핑이 달라 추후 별도 작업이 필요해요.",
  },
  {
    q: "특정 단어는 교정에서 제외하고 싶어요.",
    a: "환경설정 > 예외 단어 탭에서 단어를 추가하면 교정 대상에서 빠집니다.",
  },
  {
    q: "어떤 macOS 버전에서 동작하나요?",
    a: "macOS 14 (Sonoma) 이상에서 동작합니다.",
  },
];
---

<Layout>
  <header class="nav">
    <div class="container nav-row">
      <a href="/" class="brand" aria-label="떄가아니라때 홈">
        <img src="/logo_transparent.png" alt="" width="26" height="26" />
        <span class="brand-text">
          <span class="strike-wrong">떄</span><span class="brand-tail"
            >가 아니라 </span
          ><span class="right-glyph">때</span>
        </span>
      </a>
      <nav class="nav-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={dmgUrl} class="nav-cta">다운로드</a>
      </nav>
    </div>
  </header>

  <main>
    <section class="hero">
      <div class="container hero-inner">
        <h1 class="hero-title">
          세상에<br />
          <span class="hero-line"
            ><span class="strike-wrong">떄</span> 라는 말은</span
          ><br />
          <span class="hero-emph">없다.</span>
        </h1>

        <p class="hero-sub">
          분명 '때' 라고 쳤는데 화면엔 '떄'.<br class="break-md" />
          빠르게 칠수록 Shift 가 모음까지 따라옵니다.<br
            class="break-md"
          />
          찍히는 순간, 알아서 바꿔드릴게요.
        </p>

        <div class="cta-row">
          <a href={dmgUrl} class="btn btn-primary">
            <span class="btn-arrow" aria-hidden="true">↓</span>
            <span>지금 다운로드</span>
          </a>
          <a
            href={repoUrl}
            target="_blank"
            rel="noopener"
            class="btn btn-ghost">GitHub 코드 보기</a
          >
        </div>

        <div class="hero-demo" aria-hidden="true">
          <div class="demo-pair">
            <span class="demo-glyph wrong"
              ><span class="strike-wrong">쨰</span></span
            >
            <span class="demo-arrow">→</span>
            <span class="demo-glyph right">째</span>
          </div>
          <div class="demo-caption">
            ㅉ + Shift + ㅒ 가 떨어진 결과
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">
          사실 이런 글자들은,<br />
          <span class="hl">한국어에 없습니다.</span>
        </h2>
        <div class="explainer">
          <p>
            표준국어대사전, 우리말샘 어디를 뒤져도 떄·꺠·뺴·쨰 같은 단어는 등장하지 않습니다.
            한국어에서 <strong>쌍자음(ㄲ ㄸ ㅃ ㅆ ㅉ)</strong> 은 이중모음
            (ㅑ ㅕ ㅛ ㅠ ㅒ ㅖ) 과 만나지 않거든요.
            ㅏ, ㅓ, ㅗ, ㅜ 같은 단모음하고만 결합합니다.
          </p>
          <p>
            즉 위 글자들은 유니코드에는 자리를 차지하고 있지만, 실제 단어에는 단 하나도
            등장하지 않습니다. 사실상 100% Shift 를 모음까지 누른 결과의 오타라는 뜻이고요.
          </p>
          <p class="explainer-tail">
            그래서 떄가아니라때는 그 패턴이 보이면 곧장 고칩니다. 사전을 뒤질 필요도, 문맥을
            살필 필요도 없는 — 답이 정해진 오타니까요.
          </p>
        </div>
      </div>
    </section>

    <section class="section section-table">
      <div class="container">
        <h2 class="section-title">이런 10개가 자동으로 바뀝니다</h2>
        <p class="section-sub">
          앱이 손대는 모든 케이스. 그 외에는 아무것도 건드리지 않습니다.
        </p>

        <div class="mapping-grid">
          {
            mappings.map(({ wrong, right }) => (
              <div class="mapping-card">
                <div class="mapping-pair">
                  <span class="mapping-wrong">
                    <span class="strike-wrong">{wrong}</span>
                  </span>
                  <span class="mapping-arrow">→</span>
                  <span class="mapping-right">{right}</span>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">동작 방식</h2>
        <div class="features">
          {
            features.map(({ title, body }) => (
              <div class="feature">
                <h3 class="feature-title">{title}</h3>
                <p class="feature-body">{body}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-download">
      <div class="container download-card">
        <div>
          <h2 class="download-title">설치하기</h2>
          <ol class="install-steps">
            <li>아래 .dmg 다운로드</li>
            <li>
              더블클릭으로 마운트, <code>Ttae.app</code> 을 Applications 폴더로 드래그
            </li>
            <li>
              처음 실행 시 시스템 설정 &gt; 개인 정보 보호 및 보안 &gt; 손쉬운 사용 에서 권한 부여
            </li>
          </ol>
        </div>
        <div class="download-actions">
          <a href={dmgUrl} class="btn btn-primary btn-lg">
            <span class="btn-arrow" aria-hidden="true">↓</span>
            <span>지금 다운로드</span>
          </a>
          <a href={releaseUrl} target="_blank" rel="noopener" class="btn-link">
            전체 릴리스 노트 보기
          </a>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <h2 class="section-title">자주 묻는 질문</h2>
        <div class="faqs">
          {
            faqs.map(({ q, a }) => (
              <details class="faq">
                <summary>{q}</summary>
                <p>{a}</p>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <div class="footer-brand">
        <span class="strike-wrong">떄</span><span class="brand-tail"
          >가 아니라 </span
        ><span class="right-glyph">때</span>
      </div>
      <div class="footer-links">
        <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
        <a href={releaseUrl} target="_blank" rel="noopener">Releases</a>
        <a
          href="https://github.com/gmelon/ttae-not-ddae/blob/main/LICENSE"
          target="_blank"
          rel="noopener">MIT</a
        >
      </div>
      <div class="footer-meta">© 2026 떄가아니라때 contributors</div>
    </div>
  </footer>
</Layout>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: saturate(160%) blur(14px);
    -webkit-backdrop-filter: saturate(160%) blur(14px);
    background: rgba(250, 250, 246, 0.7);
    border-bottom: 1px solid var(--border);
  }
  .nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-weight: 500;
    font-size: 15px;
  }
  .brand img {
    border-radius: 6px;
  }
  .brand-text {
    display: inline-flex;
    align-items: baseline;
    gap: 0;
  }
  .brand-tail {
    color: var(--text-muted);
    font-weight: 400;
  }
  .nav-links {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    color: var(--text-muted);
  }
  .nav-links a {
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    transition: background 0.15s ease, color 0.15s ease;
    font-weight: 500;
  }
  .nav-links a:hover {
    background: var(--bg-elev);
    color: var(--text);
  }
  .nav-cta {
    color: #fff !important;
    background: var(--accent);
    border: 1px solid var(--accent);
  }
  .nav-cta:hover {
    background: var(--accent-hover) !important;
  }

  .hero {
    padding: 110px 0 84px;
    text-align: center;
  }
  .hero-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 26px;
  }
  .hero-title {
    font-size: clamp(44px, 7.4vw, 80px);
    font-weight: 600;
    letter-spacing: -0.028em;
    line-height: 1.1;
  }
  .hero-line {
    display: inline-block;
    padding: 0 0.05em;
  }
  .hero-emph {
    color: var(--accent);
    font-weight: 700;
  }
  .hero-sub {
    max-width: 580px;
    color: var(--text-muted);
    font-size: clamp(16px, 1.55vw, 18.5px);
    font-weight: 400;
    line-height: 1.7;
  }
  .break-md {
    display: none;
  }
  @media (min-width: 720px) {
    .break-md {
      display: inline;
    }
  }
  .cta-row {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
    margin-top: 4px;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 13px 22px;
    border-radius: var(--radius-sm);
    font-weight: 500;
    font-size: 15px;
    transition: transform 0.06s ease, background 0.15s ease,
      border-color 0.15s ease, box-shadow 0.15s ease;
    border: 1px solid transparent;
    will-change: transform;
  }
  .btn:active {
    transform: translateY(1px);
  }
  .btn-primary {
    background: var(--accent);
    color: #fff;
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.4) inset,
      0 4px 14px rgba(220, 38, 38, 0.22);
  }
  .btn-primary:hover {
    background: var(--accent-hover);
  }
  .btn-ghost {
    background: var(--bg-elev);
    color: var(--text);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    border-color: var(--border-strong);
  }
  .btn-arrow {
    font-size: 13px;
    opacity: 0.92;
  }
  .btn-lg {
    padding: 15px 26px;
    font-size: 15.5px;
  }

  .hero-demo {
    margin-top: 28px;
    padding: 28px 22px 22px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    width: 100%;
    max-width: 520px;
    box-shadow: 0 1px 2px rgba(15, 15, 18, 0.04),
      0 8px 24px rgba(15, 15, 18, 0.04);
  }
  .demo-pair {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
  }
  .demo-glyph {
    font-size: 56px;
    font-weight: 600;
    letter-spacing: -0.03em;
    line-height: 1;
  }
  .demo-glyph.wrong {
    color: var(--text-dim);
  }
  .demo-glyph.right {
    color: var(--accent);
  }
  .demo-arrow {
    color: var(--text-dim);
    font-size: 22px;
  }
  .demo-caption {
    margin-top: 14px;
    text-align: center;
    color: var(--text-dim);
    font-size: 13.5px;
    font-weight: 500;
  }

  .section {
    padding: 90px 0;
  }
  .section-title {
    font-size: clamp(28px, 3.6vw, 42px);
    font-weight: 600;
    letter-spacing: -0.025em;
    text-align: center;
    margin-bottom: 14px;
  }
  .section-sub {
    text-align: center;
    color: var(--text-muted);
    margin-bottom: 36px;
    font-size: 16px;
    font-weight: 400;
  }
  .hl {
    color: var(--accent);
  }

  .explainer {
    max-width: 720px;
    margin: 28px auto 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    color: var(--text-muted);
    font-size: 16.5px;
    text-align: left;
    padding: 30px 32px;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: 0 1px 2px rgba(15, 15, 18, 0.03),
      0 8px 24px rgba(15, 15, 18, 0.03);
  }
  .explainer strong {
    color: var(--text);
    font-weight: 600;
  }
  .explainer-tail {
    color: var(--text);
    border-top: 1px solid var(--border);
    padding-top: 14px;
    margin-top: 4px;
    font-weight: 500;
  }

  .mapping-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 10px;
    margin-top: 28px;
  }
  .mapping-card {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 16px;
    transition: border-color 0.15s ease, transform 0.15s ease,
      box-shadow 0.15s ease;
  }
  .mapping-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(15, 15, 18, 0.05);
  }
  .mapping-pair {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    font-size: 34px;
    font-weight: 600;
    letter-spacing: -0.03em;
  }
  .mapping-wrong {
    color: var(--text-dim);
  }
  .mapping-arrow {
    color: var(--text-dim);
    font-size: 18px;
    font-weight: 400;
  }
  .mapping-right {
    color: var(--text);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 14px;
    margin-top: 28px;
  }
  .feature {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .feature:hover {
    border-color: var(--border-strong);
    box-shadow: 0 4px 16px rgba(15, 15, 18, 0.05);
  }
  .feature-title {
    font-size: 17.5px;
    font-weight: 600;
    margin-bottom: 8px;
    letter-spacing: -0.015em;
  }
  .feature-body {
    color: var(--text-muted);
    font-size: 15px;
    line-height: 1.65;
  }

  .section-download {
    padding-top: 40px;
  }
  .download-card {
    background: linear-gradient(
      180deg,
      rgba(220, 38, 38, 0.06),
      rgba(220, 38, 38, 0.015) 60%,
      var(--bg-elev) 100%
    );
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-lg);
    padding: 38px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
    box-shadow: 0 1px 2px rgba(15, 15, 18, 0.04),
      0 16px 40px rgba(220, 38, 38, 0.06);
  }
  @media (min-width: 760px) {
    .download-card {
      grid-template-columns: 1.4fr 1fr;
    }
  }
  .download-title {
    font-size: 28px;
    font-weight: 600;
    margin-bottom: 14px;
    letter-spacing: -0.02em;
  }
  .install-steps {
    margin: 0;
    padding-left: 22px;
    color: var(--text-muted);
    line-height: 1.85;
    font-size: 15.5px;
  }
  .install-steps code {
    background: var(--bg-elev-2);
    padding: 1px 7px;
    border-radius: 5px;
    font-family: ui-monospace, SFMono-Regular, "Menlo", monospace;
    font-size: 13.5px;
    color: var(--text);
  }
  .download-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  @media (min-width: 760px) {
    .download-actions {
      align-items: flex-end;
    }
  }
  .btn-link {
    color: var(--text-muted);
    font-size: 13.5px;
    border-bottom: 1px dashed var(--border-strong);
    padding-bottom: 1px;
    font-weight: 500;
  }
  .btn-link:hover {
    color: var(--text);
  }

  .faqs {
    max-width: 720px;
    margin: 28px auto 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .faq {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 0 20px;
    overflow: hidden;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .faq[open] {
    border-color: var(--border-strong);
